# ─────────────────────────────────────────────────────────────────────────────
# Compliance Monitoring — Environment Variables
# Copy this file to .env and fill in values for your environment.
# .env is git-ignored; .env.example is committed as documentation.
# ─────────────────────────────────────────────────────────────────────────────

# Backend FastAPI URL (no trailing slash)
# Local dev (recommended): leave VITE_API_BASE unset — Vite proxies /api to localhost:8000
# Remote VM:              VITE_API_BASE=http://<your-vm-ip>:8000
# Production:               VITE_API_BASE=https://api.yourdomain.com
# VITE_API_BASE=http://localhost:8000

# Optional: override frontend dev server port (default 3000)
VITE_DEV_PORT=3000

# Optional: override Vite preview server port (default 4173)
VITE_PREVIEW_PORT=4173
